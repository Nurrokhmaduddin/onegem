APP_ENV=production          # development | production
APP_NAME="ERP Only One"

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=erp_berlian
DB_USER=erp_user
DB_PASS=GantiPasswordIni!

# Session
# SESSION_LIFETIME dalam detik (default: 28800 = 8 jam)
